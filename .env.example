# IBKR connection
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=17
USE_DELAYED_MARKET_DATA=true

# Trading controls
DRY_RUN=true
LIVE_TRADING=false

# Account/risk controls
ACCOUNT_ID=
ACCOUNT_SIZE_USD=25000
MAX_OPEN_POSITIONS=1

# SPX option settings
UNDERLYING=SPX
EXCHANGE=CBOE
CURRENCY=USD

# Strategy
STRATEGY=spx_0dte_iron_condor
TARGET_DTE=0
SHORT_DELTA=0.15
SPREAD_WIDTH=5
PUT_SPREAD_WIDTH=5
CALL_SPREAD_WIDTH=5
TAKE_PROFIT_PCT=70
STOP_LOSS_MULTIPLE=3.0
STOP_LOSS_PCT=300

# Your 0DTE SPX Iron Condor rules
CONTRACTS=1
MAX_DAILY_TRADES=1
MIN_OTM_DISTANCE_PCT=1.7
MAX_OTM_DISTANCE_PCT=2.0
MAX_VIX=25
MAX_OVERNIGHT_GAP_PCT=0.005
ENTRY_AFTER_MINUTES=60
FORCE_CLOSE_BEFORE_MINUTES=60
MARKET_TIMEZONE=America/New_York
